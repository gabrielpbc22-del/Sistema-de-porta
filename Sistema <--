local Botao = script.Parent
local Porta = script.Parent.Parent.Parent.Door
local Som = game.SoundService["Button Sound"]

local Aberto = false

Botao.MouseClick:Connect(function()
	Som:Play()
	if Aberto == false then
		for i = 1, 50 do
			Porta.CFrame = Porta.CFrame + Porta.CFrame.YVector * 0.15	
			task.wait()
		end
		Aberto = true
	else
		for i = 1, 50 do
			Porta.CFrame = Porta.CFrame - Porta.CFrame.YVector * 0.15
			task.wait()
		end
		Aberto = false
	end
end)
